NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
COOKIE_DOMAIN=localhost
DEVICE_ID=laptop-1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=root

# Mongo
MONGODB_URI=mongodb://root:root@localhost:27017/dmft_survey?authSource=admin

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=http://localhost:9000
# MINIO_PUBLIC_ENDPOINT=https://storage.example.com
MINIO_REGION=us-east-1
MINIO_BUCKET=dmft-survey-files
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_FORCE_PATH_STYLE=true
MINIO_PRESIGN_UPLOAD_EXPIRES_SECONDS=900
MINIO_PRESIGN_DOWNLOAD_EXPIRES_SECONDS=300

# Optional: protect /ready and /metrics with header x-internal-token
INTERNAL_API_TOKEN=