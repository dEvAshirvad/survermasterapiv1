# Copy to deploy/.env.production on the server and replace every CHANGE_ME value.
# Layout on VPS (your Hostinger clone):
#   /home/ubuntu/surveymaster/survermasterapiv1
#   /home/ubuntu/surveymaster/surveymasterappv1

# Path to frontend repo relative to survermasterapiv1/deploy (override if needed)
APP_BUILD_CONTEXT=../../surveymasterappv1

# --- Public access (single port) ---
# Open only PUBLIC_PORT on the VPS firewall. nginx routes:
#   /           -> web container (internal :3000)
#   /api/...    -> api container (internal :3001)
PUBLIC_PORT=3000

# Use the same host:port users type in the browser (include :3000).
# Example with VPS IP: http://203.0.113.10:3000
APP_DOMAIN=203.0.113.10:3000
NEXT_PUBLIC_API_URL=http://203.0.113.10:3000
CORS_ORIGINS=http://203.0.113.10:3000

# Optional later: standard HTTP/HTTPS on 80/443 (add ports back in compose + TLS)
# HTTP_PORT=80
# HTTPS_PORT=443

# --- API runtime ---
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
TRUST_PROXY_HOPS=1
DEVICE_ID=hostinger-kvm8-1
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN_MIN_32_CHARS

# --- MongoDB ---
MONGO_INITDB_DATABASE=dmft_survey
MONGO_INITDB_ROOT_USERNAME=dmft_root
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_MONGO_ROOT_PASSWORD_24

# --- Redis (min 12 chars in production) ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_24

# --- MinIO / file storage (not deployed yet) ---
# Leave unset. The API starts without object storage; attachments stay disabled.
# When you need uploads, add the minio service to docker-compose.prod.yml and set:
# MINIO_ENDPOINT, MINIO_PUBLIC_ENDPOINT, MINIO_BUCKET, MINIO_ACCESS_KEY_ID, MINIO_SECRET_ACCESS_KEY
