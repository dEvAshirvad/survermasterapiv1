# Copy to deploy/.env.production on the server and replace every CHANGE_ME value.
# Layout on VPS (your Hostinger clone):
#   /home/ubuntu/surveymaster/survermasterapiv1
#   /home/ubuntu/surveymaster/surveymasterappv1

# Path to frontend repo relative to survermasterapiv1/deploy (override if needed)
APP_BUILD_CONTEXT=../../surveymasterappv1

# --- Public URLs ---
APP_DOMAIN=survey.example.com
STORAGE_DOMAIN=storage.example.com
NEXT_PUBLIC_API_URL=https://survey.example.com
CORS_ORIGINS=https://survey.example.com

# --- HTTP / TLS (nginx container) ---
HTTP_PORT=80
HTTPS_PORT=443

# --- API runtime ---
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
TRUST_PROXY_HOPS=1
DEVICE_ID=hostinger-kvm8-1
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN_MIN_32_CHARS

# --- MongoDB ---
MONGO_INITDB_DATABASE=dmft_survey
MONGO_INITDB_ROOT_USERNAME=dmft_root
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_MONGO_ROOT_PASSWORD_24

# --- Redis (min 12 chars in production) ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_24

# --- MinIO / S3-compatible storage ---
# Internal Docker network URL for API -> MinIO operations.
MINIO_ENDPOINT=http://minio:9000
# Public URL for browser presigned upload/download links (nginx storage vhost).
MINIO_PUBLIC_ENDPOINT=https://storage.example.com
MINIO_REGION=us-east-1
MINIO_BUCKET=dmft-survey-files
MINIO_ACCESS_KEY_ID=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_SECRET_KEY_24
MINIO_FORCE_PATH_STYLE=true
MINIO_PRESIGN_UPLOAD_EXPIRES_SECONDS=900
MINIO_PRESIGN_DOWNLOAD_EXPIRES_SECONDS=300
